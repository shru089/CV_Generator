{
  "manifest_version": 3,
  "name": "Resume Tailor AI",
  "version": "1.0.0",
  "description": "Tailor your resume & generate cover letters for any job posting using AI",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.internshala.com/*",
        "*://*.wellfound.com/*",
        "*://*.naukri.com/*",
        "*://*.indeed.com/*",
        "*://*.glassdoor.com/*",
        "*://*.cutshort.io/*"
      ],
      "js": ["content.js"]
    }
  ]
}